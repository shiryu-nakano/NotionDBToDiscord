#!/usr/bin/env bash
exec >> /path_to/NotionDBToDiscord/logfile.log 2>&1

echo "---- $(date) cron started ----"
echo "whoami: $(whoami)"
echo "SHELL: $SHELL"
echo "PATH: $PATH"
echo "CWD(before): $(pwd)"

# プロジェクト直下へ
# 例えば，「/Users/username/Documents/NotionDBToDiscord」
cd "/path_to/NotionDBToDiscord" || { echo "cd failed"; exit 1; }
echo "CWD(after):  $(pwd)"

# 仮想環境のフルパスでPythonを直叩きする
/path_to/NotionDBToDiscord/venv/bin/python -c "import sys; print('sys.executable:', sys.executable)"

# 実行
/path_to/NotionDBToDiscord/venv/bin/python main.py

echo "---- $(date) cron finished ----"
