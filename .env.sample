# ---- Notion ----
NOTION_API_KEY=            # Notionの統合トークン（secret_...）
NOTION_DATABASE_ID=        # 32桁ID 例:c8926dcc2789c8252....
NOTION_VERSION=2022-06-28  # 省略可

# ---- Discord ----
DISCORD_WEBHOOK_URL=       # DiscordのWebhook URL（チャンネルごとに発行）

# ---- メッセージ設定 ----
# 1行目の固定メッセージ（例の挨拶）
MESSAGE_GREETING=おはようございます．今日の論文は.....
# 出力テンプレ（3行構成）。使える置換: {greeting}, {title}, {url}
MESSAGE_TEMPLATE={greeting}\n{title}\n{url}
# --- Notionで取得するプロパティ ---
SELECTED_PROPERTIES=Name,Done,URL

# ---- AtCoder ----
ATCODER_USER_ID=              # AtCoder Problems上のユーザーID
ATCODER_LEVELS=A               # カンマ区切りで問題番号(A/Bなど)を指定
ATCODER_EXCLUDE_PREFIXES=      # 除外したいコンテストIDの接頭辞。任意
ATCODER_CACHE_PATH=data/ac_cache.json  # AC済みキャッシュの保存先。省略可
MESSAGE_GREETING_ATCODER=おはようございます．今日のAtCoderの問題は.....
DISCORD_WEBHOOK_URL_ATCODER=   # DiscordのWebhook URL
